# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable (sb_publishable_…) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (server only) — Settings → API → Secret keys
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (server only) — BBS document OCR on /dashboard/hours
OPENAI_API_KEY=

# Apply schema from your machine: Settings → Database → Connection string → URI (Session pooler)
# Paste full URI with password, then: npm run db:apply
# DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Auth redirects (add both in Supabase → Auth → URL config):
#   http://127.0.0.1:3000/auth/callback
#   https://license.fyi/auth/callback
